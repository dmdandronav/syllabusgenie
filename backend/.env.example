# Copy this file to .env and fill in your values.

# --- Choose ONE provider ---

# Option A: OpenAI
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=
MODEL_NAME=gpt-4o-mini
EMBED_MODEL_NAME=text-embedding-3-small

# Option B: Groq (free tier, very fast — great for live demos)
# OPENAI_API_KEY=gsk_...
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# MODEL_NAME=llama-3.3-70b-versatile
# NOTE: Groq does not currently serve embeddings, so RAG (the /api/documents
#       endpoint) requires an OpenAI key for EMBED_MODEL_NAME even if chat
#       uses Groq. You can mix providers by hardcoding a second client in
#       app.py if needed.

# Option C: Gemini (free tier via Google AI Studio, OpenAI-compatible endpoint
# — also makes you eligible for Gemini sponsor tracks at most hackathons)
# OPENAI_API_KEY=AIza...
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# MODEL_NAME=gemini-2.0-flash

# --- Customize your assistant's personality for your hackathon idea ---
SYSTEM_PROMPT="You are a supportive study coach. Be concise, encouraging, and break down tasks into small steps."
